NODE_ENV=development
NPM_CONFIG_REGISTRY=https://registry.npmjs.org/
NEXT_PUBLIC_SITE_URL=http://localhost:3000
DATABASE_URL=postgresql://fy_user:change_me@localhost:5432/fy_site?schema=public
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-a-long-random-secret-at-least-32-chars
POSTGRES_PASSWORD=change_me
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-a-strong-admin-password
ADMIN_NAME=FY Admin
STORAGE_PROVIDER=local
LOCAL_UPLOAD_DIR=public/uploads
LOCAL_UPLOAD_PUBLIC_BASE_URL=/uploads
MAX_UPLOAD_MB=5
MAX_UPLOAD_WIDTH=4096
MAX_UPLOAD_HEIGHT=4096
MUSIC_AUDIO_MAX_BYTES=52428800

# S3-compatible object storage (Cloudflare R2 or S3). Keep secrets in .env only.
S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=
S3_FORCE_PATH_STYLE=true
